{
  "name": "mpp-compliance-doctor-mcp",
  "version": "1.0.0",
  "description": "MCP server that diagnoses MPP Scan warnings, validates paid MCP/API endpoints, and generates production-ready fixes for 402 payment challenges, OpenAPI schemas, and price hints.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mpp-compliance-doctor-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mpp",
    "mppscan",
    "402",
    "payment-required",
    "openapi",
    "stripe",
    "ai-agents",
    "claude",
    "openai",
    "vercel",
    "nextjs"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
